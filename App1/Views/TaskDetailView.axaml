<UserControl x:Class="App1.Views.TaskDetailView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:App1.ViewModels"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:u="https://irihi.tech/ursa"
             x:DataType="vm:TaskDetailViewModel">

    <UserControl.Styles>
        <Style Selector="FlyoutPresenter.DropDown">
            <Setter Property="Background" Value="#FAAA" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="MaxHeight" Value="400" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="*,Auto">
        <StackPanel Grid.Row="0" HorizontalAlignment="Stretch">
            <Border x:Name="TaskDetailPanel" Background="#FF1D1D1D" CornerRadius="10" ClipToBounds="True">      
                <StackPanel Margin="10">  
                    <Grid ColumnDefinitions="150,*" Margin="15">
                        <TextBlock Text="Name" Grid.Column="0" />
                        <TextBlock Text="{Binding TaskItem.Name}" Grid.Column="1" />
                    </Grid>

                    <Grid ColumnDefinitions="150,*" Margin="15">
                        <TextBlock Text="Description" Grid.Column="0" />
                        <TextBlock Text="{Binding TaskItem.Description}" Grid.Column="1" />
                    </Grid>

                    <Grid ColumnDefinitions="150,*" Margin="15">
                        <TextBlock Text="Category" Grid.Column="0" />
                        <TextBlock Text="{Binding TaskItem.Category}" Grid.Column="1" />
                    </Grid>
                </StackPanel>
            </Border>    
        </StackPanel>
        <UniformGrid x:Name="TaskEditBar" 
                    Background="#FF2D2D2D"
                    Rows="1" 
                    Columns="3" 
                    Grid.Row="1" 
                    HorizontalAlignment="Stretch" >
                <ToggleButton
                        Width="60" 
                        Height="40" 
                        Padding="0"
                        Margin="0 12"
                        CornerRadius="10"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        BorderBrush="Transparent"
                        IsChecked="{Binding IsDone}">
                    <Image Source="avares://App1/Assets/icons8-check-100.png"
                        Stretch="Uniform"
                        Width="35"
                        Height="35" />
                </ToggleButton>
                <Button
                        Width="60" 
                        Height="40" 
                        Padding="0"
                        Margin="0 12"
                        CornerRadius="10"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        BorderBrush="Transparent">
                    <Image Source="avares://App1/Assets/icons8-edit-100.png"
                        Stretch="Uniform"
                        Width="35"
                        Height="35" />
                </Button>
                <Button
                        Width="60" 
                        Height="40" 
                        Padding="0"
                        Margin="0 12"
                        CornerRadius="10"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        BorderBrush="Transparent"
                        Command="{Binding DeleteCommand}">
                    <Image Source="avares://App1/Assets/icons8-delete-100.png"
                        Stretch="Uniform"
                        Width="35"
                        Height="35" />
                </Button>
        </UniformGrid>       
    </Grid>
</UserControl>
