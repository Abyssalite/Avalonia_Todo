<UserControl x:Class="AppUno.Views.GroupListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:AppUno.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto">
        <StackPanel Grid.Row="0" Margin="10">
            <Button Content="Quick Task"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Command="{Binding OpenQuickTaskCommand}"
                          Padding="20,10,10,10"
                          Margin="10,5,10,5"/>

            <Grid ColumnDefinitions="8*,2*" Margin="10">
                <TextBlock Text="Group List" FontSize="20" Grid.Column="0"/>
                <Button Grid.Column="1"
                        Width="30" 
                        Height="30" 
                        Padding="0"
                        CornerRadius="30"
                        VerticalAlignment="Top"
                        BorderBrush="Transparent"
                        Background="#FFAAAAAA">
                    <Image Source="/Assets/Icons/icons8-done-100.png"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Width="30"
                           Height="30"/>
                </Button>
            </Grid>

            <ListView ItemsSource="{Binding FilteredGroupedList}"
                      BorderThickness="0"
                      Margin="10,0,10,0"
                      Background="Transparent"
                      SelectionMode="Single"
                      SelectedItem="{Binding SelectedGroup, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding List}" 
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Background="Transparent"
                                       Padding="10"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <Button Grid.Row="1"
                Width="50" 
                Height="50" 
                Margin="10"
                Padding="0"
                CornerRadius="30"
                VerticalAlignment="Center"
                BorderBrush="Transparent"
                Command="{Binding AddListCommand}"
                Background="#FFAAAAAA">
            <Image Source="/Assets/Icons/icons8-plus-100.png"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="Uniform"
                   Width="50"
                   Height="50"/>
        </Button>
    </Grid>
</UserControl>