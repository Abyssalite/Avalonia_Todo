<UserControl x:Class="App1.Components.TopBarView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:App1.Components"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:converters="clr-namespace:App1.Converters"
             x:DataType="vm:TopBarViewModel"> 

        <UserControl.Resources>
            <ResourceDictionary>
                <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
            </ResourceDictionary>
        </UserControl.Resources>
        <UserControl.Styles>
            <Style Selector="FlyoutPresenter.DropDown">
                <Setter Property="Background" Value="#FAAA" />
                <Setter Property="MinWidth" Value="150" />
                <Setter Property="MaxHeight" Value="400" />
                <Setter Property="Margin" Value="10" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="BorderBrush" Value="White" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>
        </UserControl.Styles>

                <Grid ColumnDefinitions="Auto,*,Auto">
                     <Button Grid.Column="0"
                            x:Name="BackOrDrawerButton"
                            Width="40" 
                            Height="40" 
                            Padding="0"
                            CornerRadius="30"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA"
                            Command="{Binding BackOrDrawerCommand}">
                        <Image Source="avares://App1/Assets/icons8-back-100.png"
                            Stretch="Uniform"
                            Width="40"
                            Height="40" />
                    </Button>
                    <TextBlock Grid.Column="1"  
                            Text="{Binding BarName}" 
                            FontSize="22"
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            MaxHeight="80"
                            IsVisible="{Binding !CanEditBarName}" />
                    <TextBox Grid.Column="1" 
                            Text="{Binding BarName, Mode=TwoWay}" 
                            FontSize="22"
                            Padding="8"
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            IsVisible="{Binding CanEditBarName}" />
                        
                     <ToggleButton Grid.Column="2"
                            x:Name="StarButton"
                            Width="40" 
                            Height="40" 
                            Padding="0"
                            CornerRadius="30"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA">
                        <Image Source="avares://App1/Assets/icons8-back-100.png"
                            Stretch="Uniform"
                            Width="40"
                            Height="40" />
                    </ToggleButton>
                    <Button Grid.Column="2"
                            x:Name="ButtonFlyout"
                            Width="40" 
                            Height="40" 
                            Padding="0"
                            CornerRadius="30"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA">
                        <Image Source="avares://App1/Assets/icons8-menu-100.png"
                            Stretch="Uniform"
                            Width="40"
                            Height="40" />
                        <Button.Flyout>
                            <Flyout FlyoutPresenterClasses="DropDown" Placement="BottomEdgeAlignedRight">
                                <Flyout.Content>
                                    <StackPanel VerticalAlignment="Center">
                                        <MenuItem Header="Edit" 
                                                Foreground="Black" 
                                                IsVisible="{Binding IsNotInArchive}"
                                                Command="{Binding EditCommand}" 
                                                CommandParameter="{Binding ElementName=ButtonFlyout}">
                                        </MenuItem>
                                        <MenuItem Foreground="Black"
                                                IsEnabled="{Binding IsNotMainList}"
                                                Command="{Binding ToggleArchiveCommand}"
                                                CommandParameter="{Binding ElementName=ButtonFlyout}">
                                            <MenuItem.Header>
                                                <MultiBinding Converter="{StaticResource BoolToTextConverter}" ConverterParameter="Archive">
                                                <Binding Path="IsNotInArchive" />
                                                </MultiBinding>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Header="Delete" 
                                                Foreground="Black" 
                                                IsEnabled="{Binding IsNotMainList}"
                                                Command="{Binding DeleteCommand}"
                                                CommandParameter="{Binding ElementName=ButtonFlyout}" />
                                    </StackPanel>
                                </Flyout.Content>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

</UserControl>
