<UserControl x:Class="App1.Views.TaskGroupView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:App1.ViewModels"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:converters="clr-namespace:App1.Converters"
             x:DataType="vm:TaskGroupViewModel"> 

        <UserControl.Resources>
            <ResourceDictionary>
                <converters:ArchiveEditTextConverter x:Key="ArchiveEditTextConverter" />
            </ResourceDictionary>
        </UserControl.Resources>
        <UserControl.Styles>
            <Style Selector="FlyoutPresenter.DropDown">
                <Setter Property="Background" Value="#FAAA" />
                <Setter Property="MinWidth" Value="150" />
                <Setter Property="MaxHeight" Value="400" />
                <Setter Property="Margin" Value="10" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="BorderBrush" Value="White" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>
        </UserControl.Styles>

        <Grid RowDefinitions="*,Auto">
            <StackPanel Grid.Row="0" Margin="10" x:Name="ListsStack">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="1"  
                            Text="{Binding ListName}" 
                            FontSize="30"
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            TextWrapping="Wrap"
                            MaxHeight="100"
                            IsVisible="{Binding !IsInEditMode}" />
                    <TextBox Grid.Column="1" 
                            Text="{Binding ListName, Mode=TwoWay}" 
                            FontSize="30"
                            Padding="8"
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            IsVisible="{Binding IsInEditMode}" />

                    <Button Grid.Column="2"
                            Width="40" 
                            Height="40" 
                            Padding="0"
                            CornerRadius="30"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA" 
                            x:Name="ButtonFlyout">
                        <Image Source="avares://App1/Assets/icons8-menu-100.png"
                            Stretch="Uniform"
                            Width="40"
                            Height="40" />
                        <Button.Flyout>
                            <Flyout FlyoutPresenterClasses="DropDown" Placement="BottomEdgeAlignedRight">
                                <Flyout.Content>
                                    <StackPanel VerticalAlignment="Center">
                                        <MenuItem Foreground="Black"
                                                Command="{Binding RestoreOrEditCommand}"
                                                CommandParameter="{Binding ElementName=ButtonFlyout}">
                                            <MenuItem.Header>
                                                <MultiBinding Converter="{StaticResource ArchiveEditTextConverter}" ConverterParameter="Edit">
                                                    <Binding Path="IsNotInArchive" />
                                                </MultiBinding>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Foreground="Black" 
                                                IsEnabled="{Binding IsNotMainList}"
                                                Command="{Binding ArchiveOrDeleteCommand}" 
                                                CommandParameter="{Binding ElementName=ButtonFlyout}">
                                            <MenuItem.Header>
                                                <MultiBinding Converter="{StaticResource ArchiveEditTextConverter}" ConverterParameter="Archive">
                                                    <Binding Path="IsNotInArchive" />
                                                </MultiBinding>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Header="Delete" 
                                                IsVisible="{Binding IsNotInArchive}"
                                                Foreground="Black" 
                                                Command="{Binding ShowDialogCommand}"
                                                CommandParameter="{Binding ElementName=ButtonFlyout}" />
                                    </StackPanel>
                                </Flyout.Content>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <ItemsControl ItemsSource="{Binding GroupedTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Category}" 
                                        FontSize="22" 
                                        FontWeight="Bold"
                                        Margin="10,10,100,5"
                                        Padding="10,5,10,5" 
                                        IsVisible="{Binding !$parent[UserControl].((vm:TaskGroupViewModel)DataContext).IsInEditMode}" />
                                <TextBox Text="{Binding Category, Mode=TwoWay}" 
                                        FontSize="22"
                                        Margin="10,10,100,5"
                                        Padding="10,8,10,8" 
                                        IsVisible="{Binding $parent[UserControl].((vm:TaskGroupViewModel)DataContext).IsInEditMode}" />

                                <ListBox ItemsSource="{Binding Tasks}"
                                        BorderThickness="0"
                                        Margin="10,5,10,10"
                                        Background="Transparent"
                                        SelectionMode="Single"
                                        CornerRadius="8"
                                        SelectedItem="{Binding $parent[UserControl].((vm:TaskGroupViewModel)DataContext).SelectedTask, Mode=TwoWay}"
                                        IsEnabled="{Binding !$parent[UserControl].((vm:TaskGroupViewModel)DataContext).IsInEditMode}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="5,8,5,8">
                                                <CheckBox IsChecked="{Binding IsDone}" 
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,10,0" />
                                                <TextBlock Text="{Binding Name}" 
                                                        VerticalAlignment="Center"
                                                        FontSize="15"
                                                        Background="Transparent" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel> 

            <Border Grid.Row="1" 
                    x:Name="QuickAddTaskBorder" 
                    VerticalAlignment="Top" 
                    CornerRadius="10"
                    IsEnabled="{Binding IsNotInArchive}" >
                <Grid 
                    ColumnDefinitions="*,Auto"
                    Margin="20,20,20,0"
                    VerticalAlignment="Top">
                    <TextBox Grid.Column="0"
                            x:Name="QuickAddTaskTextBox"
                            Watermark="New Task" 
                            Padding="8"                
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            FontSize="16"
                            IsVisible="{Binding !IsInEditMode}"
                            Text="{Binding QuickAddTaskName, Mode=TwoWay}" />
                   <Button Grid.Column="0"
                            Width="50" 
                            Height="50" 
                            Padding="0"
                            Margin="0,0,10,0"
                            CornerRadius="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA"
                            IsVisible="{Binding IsInEditMode}"
                            Command="{Binding CancelCommand}">
                        <Image Source="avares://App1/Assets/icons8-plus-100.png"
                            Stretch="Uniform"
                            Width="50"
                            Height="50" />
                    </Button>  

                    <Button Grid.Column="1"
                            Width="50" 
                            Height="50" 
                            Padding="0"
                            Margin="10,0,0,0"
                            CornerRadius="30"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA"
                            Command="{Binding AddTaskViewCommand}">
                        <Image Source="avares://App1/Assets/icons8-plus-100.png"
                            Stretch="Uniform"
                            Width="50"
                            Height="50" />
                    </Button>    
                </Grid>
            </Border>
        </Grid>
</UserControl>
