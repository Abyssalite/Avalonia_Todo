<UserControl x:Class="App1.Views.AddTaskView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="clr-namespace:App1.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AddTaskViewModel">   
        
        <StackPanel HorizontalAlignment="Stretch" >
            <Border x:Name="AddTaskPanel" Background="#FF1D1D1D" CornerRadius="10" ClipToBounds="True">      
                <StackPanel Margin="10"> 
                    <TextBox Watermark="Task name" Text="{Binding NewTaskName}" Margin="8" />
                    <TextBox Watermark="Description" Text="{Binding TaskDesc}" Margin="8" />
                    <TextBox Watermark="Category" Text="{Binding TaskCatalog}" Margin="8" />
                    <Grid ColumnDefinitions="Auto,*"  Margin="5,4,0,0">
                        <Button Grid.Column="0"
                            Content="Add task"
                            HorizontalAlignment="Left"
                            Command="{Binding SaveTaskCommand}"
                            Padding="10" 
                            Margin="10" />   
                        <Button Grid.Column="1"
                            Content="Cancel"
                            HorizontalAlignment="Left"
                            Command="{Binding CancelCommand}"
                            Padding="10" 
                            Margin="10" />   
                    </Grid>
                </StackPanel>         
            </Border>    
        </StackPanel>         
</UserControl>
