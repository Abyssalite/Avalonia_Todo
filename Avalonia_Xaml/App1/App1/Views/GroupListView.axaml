<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:App1.ViewModels"
             x:Class="App1.Views.GroupListView"
             x:DataType="vm:GroupListViewModel"> 

        <Grid Grid.Column="0" RowDefinitions="Auto,Auto">
            <StackPanel Grid.Row="0" Margin="10">
                <MenuItem Header="Quick Task"
                            Command="{Binding OpenQuickTaskCommand}"
                            Padding="20,10,10,10"
                            Margin="10,5,10,5"/>
                <Grid ColumnDefinitions="9*,1*" Margin="10">
                    <TextBlock Text="Group List" FontSize="20" Grid.Column="0"/>
                    <Button Grid.Column="1"
                            Width="30" 
                            Height="30" 
                            Padding="0"
                            CornerRadius="30"
                            VerticalAlignment="Top"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA">
                        <Image Source="avares://App1/Assets/icons8-done-100.png"
                            Stretch="Uniform"
                            Width="30"
                            Height="30" />
                    </Button>
                </Grid>
                <!-- Clickable Task Boxes -->
                <ListBox ItemsSource="{Binding FilteredGroupedList}"
                         BorderThickness="0"
                         Margin="10,0,10,0"
                         Background="Transparent"
                         SelectionMode="Single"
                         SelectedItem="{Binding $parent[UserControl].((vm:GroupListViewModel)DataContext).SelectedGroup, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" >
                                <TextBlock Text="{Binding List}" 
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Background="Transparent"
                                           Padding="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>     
            </StackPanel>   
                         
            <Button Grid.Row="1"
                    Width="50" 
                    Height="50" 
                    Margin="10"
                    Padding="0"
                    CornerRadius="30"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderBrush="Transparent"
                    Background="#FAAA">
                <Image Source="avares://App1/Assets/icons8-plus-100.png"
                    Stretch="Uniform"
                    Width="50"
                    Height="50" />
            </Button>
        </Grid>
</UserControl>
