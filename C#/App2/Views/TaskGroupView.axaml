<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:App2.ViewModels"
    x:Class="App2.Views.TaskGroupView"
    x:DataType="vm:TaskGroupViewModel"> 
        <Grid RowDefinitions="*,Auto">
            <StackPanel Grid.Row="0" Margin="10">
                <TextBlock Text="{Binding ListName}" FontSize="20" Grid.Column="0"/>
                <ItemsControl ItemsSource="{Binding GroupedTasks}" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Category Header (non-clickable) -->
                                <TextBlock  Text="{Binding Category}" 
                                            FontSize="16" 
                                            Background="Transparent"
                                            FontWeight="Bold"
                                            Padding="5" 
                                            Margin="5,0,0,0"/>
                                <!-- Clickable Task Boxes -->
                                <ListBox ItemsSource="{Binding Tasks}"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding $parent[UserControl].((vm:TaskGroupViewModel)DataContext).SelectedTask, Mode=TwoWay}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                                <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" 
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Background="Transparent"
                                                        Padding="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel> 

            <Button Grid.Row="1"
                    Width="50" 
                    Height="50" 
                    Margin="10"
                    Padding="0"
                    CornerRadius="30"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderBrush="Transparent"
                    Background="#FAAA"
                    Command="{Binding AddTaskViewCommand}">
                <Image Source="avares://App2/Assets/icons8-plus-100.png"
                    Stretch="Uniform"
                    Width="50"
                    Height="50" />
            </Button>               
        </Grid>
</UserControl>
