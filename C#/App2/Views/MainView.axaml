<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:App2.ViewModels"
    x:Class="App2.Views.MainView"
    x:DataType="vm:MainViewModel"> 
   <Grid ColumnDefinitions="1*,2*">
        <!-- Left: Task List -->
        <Grid Grid.Column="0" RowDefinitions="*,Auto">
            <StackPanel Grid.Row="0" Margin="10">
                <Grid ColumnDefinitions="8*,2*" Margin="10">
                    <TextBlock Text="Task List" FontSize="20" Grid.Column="0"/>
                    <Button Grid.Column="1"
                            Width="30" 
                            Height="30" 
                            Padding="0"
                            CornerRadius="30"
                            VerticalAlignment="Top"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            BorderBrush="Transparent"
                            Background="#FAAA">
                        <Image Source="avares://App2/Assets/icons8-done-100.png"
                            Stretch="Uniform"
                            Width="30"
                            Height="30" />
                    </Button>
                </Grid>
                <ItemsControl ItemsSource="{Binding GroupList}" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>           
                                <ListBox ItemsSource="{Binding List}"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        SelectionMode="Single">
                                <local:TaskGroupView DataContext="{Binding Group}" Margin="5"/>

                                </ListBox>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>                
            <Button Grid.Row="1"
                    Command="{Binding AddTaskViewCommand}"
                    Width="60" 
                    Height="60" 
                    Margin="10"
                    Padding="0"
                    CornerRadius="30"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    BorderBrush="Transparent"
                    Background="#FAAA">
                <Image Source="avares://App2/Assets/icons8-plus-100.png"
                    Stretch="Uniform"
                    Width="60"
                    Height="60" />
            </Button>
        </Grid>

        <!-- Right: Task Detail -->
        <ContentControl Grid.Column="1"
                        Content="{Binding TaskDetailView}" />
    </Grid>

</UserControl>
