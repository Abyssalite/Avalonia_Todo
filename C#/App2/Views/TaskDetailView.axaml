<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:App2.ViewModels"
    x:Class="App2.Views.TaskDetailView"
    x:DataType="vm:TaskDetailViewModel">
    
    <Grid>
        <StackPanel HorizontalAlignment="Stretch" Margin="10">
            <TextBlock Text="Task Detail" FontSize="30" Margin="10" HorizontalAlignment="Center"/>
            
            <Grid ColumnDefinitions="150,*" Margin="20">
                <TextBlock Text="Name" Grid.Column="0"/>
                <TextBlock Text="{Binding Task.Name}" Grid.Column="1"/>
            </Grid>

            <Grid ColumnDefinitions="150,*" Margin="20">
                <TextBlock Text="Description" Grid.Column="0"/>
                <TextBlock Text="{Binding Task.Description}" Grid.Column="1"/>
            </Grid>

            <Grid ColumnDefinitions="150,*" Margin="20">
                <TextBlock Text="Category" Grid.Column="0"/>
                <TextBlock Text="{Binding Task.Category}" Grid.Column="1"/>
            </Grid>
        </StackPanel>
    </Grid>


</UserControl>
