<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:App2.ViewModels"
    x:Class="App2.Views.TaskDetailView"
    x:DataType="vm:TaskDetailViewModel">
    
    <StackPanel Margin="10">
        <TextBlock Text="Task Detail" FontSize="20"/>
        <TextBlock Text="{Binding Task.Name}" />
        <TextBlock Text="{Binding Task.Description}" />
        <TextBlock Text="{Binding Task.Category}" />
        <Button Content="Back" Command="{Binding GoBackCommand}" Margin="0,10,0,0"/>
    </StackPanel>
</UserControl>
