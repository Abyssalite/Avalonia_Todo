<Window 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="300" Height="160"
    xmlns:vm="using:App2.ViewModels"
    x:Class="App2.Views.CustomDialog"
    Icon="/Assets/avalonia-logo.ico"
    Title="Warning"
    WindowStartupLocation="CenterOwner"
    CanResize="False"
    Opacity="0.80">
    
    <Grid RowDefinitions="6*,4*">
    <TextBlock Grid.Row="0" 
            x:Name="MessageText" 
            Text="Default"
            FontSize="20"
            Margin="0,0,0,10" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center"/>
    <Grid Grid.Row="1" ColumnDefinitions="5*,5*">
        <Button 
            x:Name="YesButton" 
            Content="Default" 
            Click="OnYesClick"
            Padding="10" 
            Margin="50,0,0,20"
            Grid.Column="0"/>
        <Button 
            x:Name="NoButton" 
            Content="Cancel" 
            IsVisible="false"
            Click="OnNoClick"
            Padding="10" 
            Margin="40,0,0,20"
            Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>
